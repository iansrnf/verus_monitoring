DATABASE_URL=postgres://postgres:password@localhost:5432/verus_monitoring
POSTGRES_SSL=false
CONFIG_API_TOKEN=optional-shared-token-for-mobile-api

# Web dashboard administrator login.
# This protects browser pages only; /api routes remain available for the Android app.
# If omitted, the app falls back to these same default values.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
# Optional: used to sign one-day browser login sessions. If omitted, ADMIN_PASSWORD is used.
ADMIN_SESSION_SECRET=change-this-long-random-session-secret

# Device table expected by the dashboard:
# create table device (
#   id integer generated always as identity primary key,
#   name text,
#   hash text,
#   config text,
#   status boolean,
#   shares text,
#   cpu_core integer,
#   temp text,
#   screen_shot bytea,
#   created_at timestamptz
# );

# Config table used by the dashboard config loader:
# create table my_config (
#   id integer generated always as identity primary key,
#   created_at timestamptz,
#   url text,
#   port text,
#   wallet text,
#   password text
# );

# Investment dashboard tables:
# create table investments (
#   id integer generated always as identity primary key,
#   name text,
#   cost double precision,
#   created_at timestamptz,
#   description text
# );
#
# create table income (
#   id integer generated always as identity primary key,
#   amount double precision,
#   description text,
#   created_at timestamptz,
#   inv_id integer references investments(id) on delete cascade
# );
#
# Existing databases that use investment_id instead of inv_id are also supported.
